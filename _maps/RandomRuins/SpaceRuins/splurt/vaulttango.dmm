/obj/structure/filingcabinet/chestdrawer,
/obj/item/paper{
	default_raw_text = "Log name A10-01. Log date 9/17/2560. A10 rotation is beginning. Relocating from location Delta to here, location Tango. Expecting low traffic, considering proximity to Nanotrasen station radio activity. Gonna keep an eye out for that. Thankful for the calm position. Ardere.";
	name = "Report A10-01"
	},
/obj/item/paper{
	default_raw_text = "Log name A10-28. Log date 11/13/2560. Looks like another research station got infiltrated a few days ago, just getting word of it now. Activated the self-destruct terminal before anything got stolen. Nobody made it. Expecting some in and out at the vault for mech pick-up, and probably some cash. Probably a lot. Ardere.";
	name = "Report A10-28"
	},
/obj/item/paper{
	default_raw_text = "Log name A10-35. Log date 02/21/2561. Expecting a shipment today from PC, something about storing a few unused cores for experiments at a later date. Expecting in 3-5 days, depending on how happy the engines are on the transport vessel. We'll see how it goes. Ardere.";
	name = "Report A10-35"
	},
/obj/item/paper{
	default_raw_text = "Log name A10-52. Log date 03/28/2561. As of today, this vault will remain self-sustaining and unmanned. We no longer require workers aboard this station. The perimeter turrets will remain operable until further notice. If you have any inquiries, please see me directly. Ardere.";
	name = "Report A10-52"
	},
